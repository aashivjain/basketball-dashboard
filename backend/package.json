{
  "name": "basketball-dashboard-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node --loader ts-node/esm src/server.ts",
    "build": "tsc && node -e \"require('fs').copyFileSync('src/db/schema.sql', 'dist/db/schema.sql')\"",
    "start": "node dist/server.js",
    "init-db": "node scripts/init-db.mjs",
    "test": "echo 'Run from project root: python scripts/run_all_tests.py'",
    "test:api": "echo 'Run from project root: python scripts/test_api.py'",
    "test:security": "echo 'Run from project root: python scripts/security_test.py'"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.1",
    "helmet": "^7.2.0",
    "sqlite3": "^5.1.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
